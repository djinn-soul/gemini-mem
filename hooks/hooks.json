{
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "gemini-mem-after-agent",
            "description": "Capture and persist durable memory from completed turns",
            "timeout": 180000,
            "command": "node \"${extensionPath}${/}dist${/}hooks${/}after-agent.js\""
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "gemini-mem-before-agent",
            "description": "Inject relevant stored memories before response generation",
            "timeout": 120000,
            "command": "node \"${extensionPath}${/}dist${/}hooks${/}before-agent.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "gemini-mem-session-start",
            "description": "Inject baseline project memory at session start",
            "timeout": 20000,
            "command": "node \"${extensionPath}${/}dist${/}hooks${/}session-start.js\""
          }
        ]
      }
    ]
  }
}
